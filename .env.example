# Force Graphify to use local Ollama
export GRAPHIFY_BACKEND="openai" # Graphify uses the OpenAI-compatible endpoint
export OPENAI_BASE_URL="http://localhost:11434/v1"
export OPENAI_API_BASE="http://localhost:11434/v1"
export OPENAI_API_KEY="ollama"
export GRAPHIFY_MODEL="qwen2.5-coder:7b" # Default fast coder model (e.g., qwen2.5-coder:7b or qwen2.5-coder:32b)
export OLLAMA_API_KEY=local
