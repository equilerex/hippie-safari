{
  "nodes": [
    {
      "id": "docs_technical_project_descriptio_hippysafari",
      "label": "Hippy Safari",
      "file_type": "concept",
      "source_file": "docs/technical-project-descriptio.md",
      "source_location": "Section 1: Project Overview",
      "rationale": "Interactive festival installation where content drives the entire system; adding, removing or changing content should require as little firmware work as possible"
    },
    {
      "id": "docs_physical_project_description_observationstation",
      "label": "Observation Station",
      "file_type": "concept",
      "source_file": "docs/physical-project-description.md",
      "source_location": "Physical Installation section",
      "rationale": "Integrated into coffee shop or similar structure, designed for unattended operation throughout event with electronics protected from weather and visitor access"
    },
    {
      "id": "docs_technical_project_descriptio_species",
      "label": "Species",
      "file_type": "concept",
      "source_file": "docs/technical-project-descriptio.md",
      "source_location": "Visitor Interaction section",
      "rationale": "Primary narration buttons representing the main content category"
    },
    {
      "id": "docs_technical_project_descriptio_intro",
      "label": "Intro",
      "file_type": "concept",
      "source_file": "docs/technical-project-descriptio.md",
      "source_location": "Visitor Interaction section",
      "rationale": "Dedicated start button treated internally as normal species to avoid unnecessary special-case firmware"
    },
    {
      "id": "docs_technical_project_descriptio_eastereggs",
      "label": "Easter Eggs",
      "file_type": "concept",
      "source_file": "docs/technical-project-descriptio.md",
      "source_location": "Visitor Interaction section",
      "rationale": "Hidden or alternative interactions outside normal species selection, triggered by special conditions like simultaneous button presses"
    },
    {
      "id": "docs_technical_project_descriptio_contentvariants",
      "label": "Content Variants",
      "file_type": "concept",
      "source_file": "docs/technical-project-descriptio.md",
      "source_location": "Content Variants section",
      "rationale": "Multiple variants per content item (default, friday, night, halloween, christmas) selected via configuration rather than hardcoded names"
    },
    {
      "id": "docs_physical_project_description_esp32a1s",
      "label": "ESP32-A1S Audio Kit",
      "file_type": "concept",
      "source_file": "docs/physical-project-description.md",
      "source_location": "Hardware section",
      "rationale": "Planned controller subject to prototype verification; exact board revision and audio codec (AC101/ES8388) must be verified before development"
    },
    {
      "id": "docs_technical_project_descriptio_audiopath",
      "label": "Audio Signal Path",
      "file_type": "rationale",
      "source_file": "docs/technical-project-descriptio.md",
      "source_location": "Audio section",
      "rationale": "Preferred signal path: ESP32-A1S → 3.5mm audio output → Bluetooth transmitter → Bluetooth speaker(s); local wired speaker retained as backup; additional amplification only if testing demonstrates need"
    },
    {
      "id": "docs_technical_project_descriptio_rtc",
      "label": "RTC (Real Time Clock)",
      "file_type": "concept",
      "source_file": "docs/technical-project-descriptio.md",
      "source_location": "Time section",
      "rationale": "Preferred source of persistent local time; network time is optional and should improve accuracy rather than enable core functionality"
    },
    {
      "id": "docs_technical_project_descriptio_networktime",
      "label": "Network Time",
      "file_type": "concept",
      "source_file": "docs/technical-project-descriptio.md",
      "source_location": "Time section",
      "rationale": "Optional enhancement to improve RTC accuracy; should not be required for core functionality"
    },
    {
      "id": "docs_technical_project_descriptio_contentdiscovery",
      "label": "Content Discovery",
      "file_type": "rationale",
      "source_file": "docs/technical-project-descriptio.md",
      "source_location": "Content Structure section",
      "rationale": "Firmware discovers folders automatically rather than containing hardcoded list of species or modes; enables adding new content without firmware changes"
    },
    {
      "id": "docs_technical_project_descriptio_gracefulfallback",
      "label": "Graceful Fallback Behavior",
      "file_type": "rationale",
      "source_file": "docs/technical-project-descriptio.md",
      "source_location": "Graceful Behaviour section",
      "rationale": "Installation should continue operating when optional features unavailable: missing variant uses default, missing mode continues normal playback, network time unavailable uses RTC, index outside range restarts from first recording"
    },
    {
      "id": "docs_technical_project_descriptio_designprinciples",
      "label": "Design Principles",
      "file_type": "rationale",
      "source_file": "docs/technical-project-descriptio.md",
      "source_location": "Design Principles section",
      "rationale": "Minimize special-case firmware; keep firmware independent of individual species/modes; new content addable without firmware changes; prefer graceful fallbacks over visible failures; prioritize stability over features"
    },
    {
      "id": "docs_technical_project_descriptio_engineeringphilosophy",
      "label": "Engineering Philosophy",
      "file_type": "rationale",
      "source_file": "docs/technical-project-descriptio.md",
      "source_location": "Engineering Philosophy section",
      "rationale": "One-off art installation preferring simple robust solutions over reusable architectures or premature optimization; prototype first, optimize only when testing demonstrates need; use established libraries"
    },
    {
      "id": "docs_physical_project_description_buttonled",
      "label": "Button LEDs",
      "file_type": "concept",
      "source_file": "docs/physical-project-description.md",
      "source_location": "Hardware section",
      "rationale": "Hardware-driven and not controlled by firmware; final button count and physical layout are construction decisions"
    },
    {
      "id": "docs_physical_project_description_speakerconfiguration",
      "label": "Speaker Configuration",
      "file_type": "concept",
      "source_file": "docs/physical-project-description.md",
      "source_location": "Hardware section",
      "rationale": "Speaker placement and quantity should be determined through real-world testing"
    },
    {
      "id": "docs_physical_project_description_sdcardcontent",
      "label": "SD-Card Content Storage",
      "file_type": "concept",
      "source_file": "docs/physical-project-description.md",
      "source_location": "Storage section",
      "rationale": "Prototype SD-card content loading before building higher-level logic; keep content structure flexible so new species and variants can be added without firmware changes"
    },
    {
      "id": "docs_technical_project_descriptio_configurationapproach",
      "label": "Configuration Approach",
      "file_type": "rationale",
      "source_file": "docs/technical-project-descriptio.md",
      "source_location": "Configuration section",
      "rationale": "Species-level configuration recommended over variant-level for simplicity, single source of truth, easier validation, and shared settings across variants"
    },
    {
      "id": "docs_physical_project_description_audiocodec",
      "label": "Audio Codec",
      "file_type": "concept",
      "source_file": "docs/physical-project-description.md",
      "source_location": "Engineering Notes - Hardware section",
      "rationale": "Must verify which codec (AC101/ES8388 or equivalent) the ESP32-A1S board contains before selecting software support"
    },
    {
      "id": "docs_technical_project_descriptio_utctimestamp",
      "label": "UTC Timestamp Format",
      "file_type": "concept",
      "source_file": "docs/technical-project-descriptio.md",
      "source_location": "Time section",
      "rationale": "Store timestamps using standard UTC formats for consistency and reliability"
    },
    {
      "id": "docs_physical_project_description_deploymentchecklist",
      "label": "Deployment Checklist",
      "file_type": "rationale",
      "source_file": "docs/physical-project-description.md",
      "source_location": "Deployment section",
      "rationale": "Maintain separate from requirements; keep backup copies of firmware, configuration and audio content; record operational lessons learned after event for future iterations"
    },
    {
      "id": "docs_physical_project_description_contentflexibility",
      "label": "Content Flexibility",
      "file_type": "rationale",
      "source_file": "docs/physical-project-description.md",
      "source_location": "Content section",
      "rationale": "Species, easter eggs, names, button labels and narration are content decisions; new content should be organized so it can be added without firmware changes"
    },
    {
      "id": "docs_technical_project_descriptio_contentstructure",
      "label": "Content Directory Structure",
      "file_type": "rationale",
      "source_file": "docs/technical-project-descriptio.md",
      "source_location": "Content Structure section",
      "rationale": "Hierarchical folder structure with audio/species/ and audio/easter-egg/ containing individual content folders with mode subfolders; _intro sorts first alphabetically"
    },
    {
      "id": "docs_physical_project_description_weatherprotection",
      "label": "Weather Protection",
      "file_type": "concept",
      "source_file": "docs/physical-project-description.md",
      "source_location": "Physical Installation section",
      "rationale": "Electronics protected from weather and visitor access; maintenance access limited to operators"
    }
